generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── FAMILY ─────────────────────────────────────────────

model Family {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique @default(cuid())
  tvToken    String   @unique @default(cuid()) // for TV/kiosk dashboard
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members    User[]
  chores     Chore[]
  storeItems StoreItem[]
  allowanceRules AllowanceRule[]
  familySettings FamilySettings?
}

// ─── USER ───────────────────────────────────────────────

enum UserRole {
  PARENT
  CHILD
}

model User {
  id           String   @id @default(cuid())
  familyId     String
  name         String
  role         UserRole
  age          Int?
  email        String?  @unique
  passwordHash String?
  pin          String?  // 4-digit hashed PIN for kids
  avatarId     Int      @default(1) // 1-16 avatar selection
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  family             Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  wallet             Wallet?
  createdChores      Chore[]         @relation("ChoreCreator")
  assignedChores     Chore[]         @relation("ChoreAssignee")
  claimedInstances   ChoreInstance[] @relation("InstanceClaimer")
  assignedInstances  ChoreInstance[] @relation("InstanceAssignee")
  savingsGoals       SavingsGoal[]
  investments        Investment[]
  achievements       UserAchievement[]
  notifications      Notification[]
  choreBids          ChoreBid[]
  purchaseRequests   PurchaseRequest[]
  allowanceRules     AllowanceRule[]

  @@index([familyId])
}

// ─── CHORES ─────────────────────────────────────────────

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Recurrence {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

model Chore {
  id               String     @id @default(cuid())
  familyId         String
  createdById      String
  title            String
  description      String?
  dollarValue      Float
  estimatedMinutes Int?
  difficulty       Difficulty @default(MEDIUM)
  recurrence       Recurrence @default(ONCE)
  recurrenceRule   String?    // cron-like rule for CUSTOM
  categoryIcon     String?    // icon identifier
  photoUrl         String?    // reference photo for the chore
  assignedToId     String?    // null = open pool
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  family     Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy  User            @relation("ChoreCreator", fields: [createdById], references: [id])
  assignedTo User?           @relation("ChoreAssignee", fields: [assignedToId], references: [id])
  instances  ChoreInstance[]

  @@index([familyId])
  @@index([assignedToId])
}

enum ChoreStatus {
  AVAILABLE
  CLAIMED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  REDO
}

model ChoreInstance {
  id               String      @id @default(cuid())
  choreId          String
  assignedToId     String?
  claimedById      String?
  status           ChoreStatus @default(AVAILABLE)
  dueDate          DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  timeSpentSeconds Int?
  proofPhotoUrl    String?
  parentNote       String?
  bonusAmount      Float?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  chore       Chore         @relation(fields: [choreId], references: [id], onDelete: Cascade)
  assignedTo  User?         @relation("InstanceAssignee", fields: [assignedToId], references: [id])
  claimedBy   User?         @relation("InstanceClaimer", fields: [claimedById], references: [id])
  transactions Transaction[]
  bids         ChoreBid[]

  @@index([choreId])
  @@index([claimedById])
  @@index([status])
}

// ─── WALLET & TRANSACTIONS ─────────────────────────────

model Wallet {
  id               String  @id @default(cuid())
  userId           String  @unique
  availableBalance Float   @default(0)
  savedBalance     Float   @default(0)
  investedBalance  Float   @default(0)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

enum TransactionType {
  EARNING
  SAVING
  SPENDING
  INVESTMENT
  MATURATION
  BONUS
  MATCH
}

model Transaction {
  id              String          @id @default(cuid())
  walletId        String
  type            TransactionType
  amount          Float
  description     String
  choreInstanceId String?
  investmentId    String?
  savingsGoalId   String?
  createdAt       DateTime        @default(now())

  wallet        Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  choreInstance ChoreInstance? @relation(fields: [choreInstanceId], references: [id])
  investment    Investment?    @relation(fields: [investmentId], references: [id])
  savingsGoal   SavingsGoal?   @relation(fields: [savingsGoalId], references: [id])

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

// ─── SAVINGS GOALS ──────────────────────────────────────

model SavingsGoal {
  id              String   @id @default(cuid())
  userId          String
  name            String
  targetAmount    Float
  currentAmount   Float    @default(0)
  imageUrl        String?
  parentMatchRate Float?   // e.g. 0.5 = $0.50 per $1 saved
  isCompleted     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

// ─── ACHIEVEMENTS ────────────────────────────────────────

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "first_chore", "savings_10"
  name        String
  description String
  emoji       String   // display emoji
  category    String   // "chores", "savings", "investing", "streak"
  threshold   Int      // number required to unlock
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

// ─── NOTIFICATIONS ──────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "chore_submitted", "chore_approved", "chore_rejected", "achievement_unlocked", "investment_matured", "savings_match", "streak"
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  String?  // JSON string for extra data
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ─── INVESTMENTS ────────────────────────────────────────

enum InvestmentStatus {
  ACTIVE
  MATURED
  WITHDRAWN
}

model Investment {
  id              String           @id @default(cuid())
  userId          String
  principalAmount Float
  status          InvestmentStatus @default(ACTIVE)
  lockDays        Int              // 7, 14, or 30
  maturationDate  DateTime
  returnAmount    Float?           // set by parent when matured
  parentNote      String?
  createdAt       DateTime         @default(now())
  maturedAt       DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([status])
  @@index([maturationDate])
}

// ─── CHORE BIDS (Marketplace) ───────────────────────────

model ChoreBid {
  id              String   @id @default(cuid())
  choreInstanceId String
  userId          String
  amount          Float
  message         String?
  status          String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  choreInstance ChoreInstance @relation(fields: [choreInstanceId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([choreInstanceId])
  @@index([userId])
  @@index([status])
}

// ─── STORE & PURCHASES ──────────────────────────────────

model StoreItem {
  id          String   @id @default(cuid())
  familyId    String
  name        String
  description String?
  price       Float
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  family    Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)
  purchases PurchaseRequest[]

  @@index([familyId])
}

model PurchaseRequest {
  id          String   @id @default(cuid())
  userId      String
  storeItemId String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  parentNote  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeItem StoreItem @relation(fields: [storeItemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ─── ALLOWANCE ──────────────────────────────────────────

model AllowanceRule {
  id         String   @id @default(cuid())
  familyId   String
  userId     String   // which child receives
  amount     Float
  frequency  String   // "WEEKLY" or "MONTHLY"
  dayOfWeek  Int?     // 0=Sun..6=Sat (for WEEKLY)
  dayOfMonth Int?     // 1-28 (for MONTHLY)
  isActive   Boolean  @default(true)
  lastPaidAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([userId])
}

// ─── FAMILY SETTINGS (Parent Controls) ──────────────────

model FamilySettings {
  id                  String  @id @default(cuid())
  familyId            String  @unique
  maxDailyEarnings    Float?  // cap per kid per day
  maxSpendingPerDay   Float?  // spending limit per day
  investmentApproval  Boolean @default(false) // require parent approval for investments
  investmentMaxAmount Float?  // max investment amount without approval
  savingsInterestRate Float?  // weekly interest rate on savings (e.g., 0.02 = 2%)

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}
